{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge-import.schema.json",
  "title": "AI Prompt Studio Knowledge Import Schema",
  "description": "Schema for Internal Knowledge JSON generated by the Knowledge Importer.",
  "type": "object",

  "required": [
    "metadata",
    "registries"
  ],

  "properties": {
    "metadata": {
      "type": "object",

      "required": [
        "profile",
        "version",
        "generatedAt"
      ],

      "properties": {
        "profile": {
          "type": "string"
        },

        "version": {
          "type": "string"
        },

        "generatedAt": {
          "type": "string"
        }
      }
    },

    "registries": {
      "type": "object",

      "required": [
        "domains",
        "canonicals",
        "relationships",
        "intents"
      ],

      "properties": {

        "domains": {
          "type": "array",

          "items": {
            "type": "object",

            "required": [
              "id",
              "name",
              "description"
            ],

            "properties": {

              "id": {
                "type": "string"
              },

              "name": {
                "type": "string"
              },

              "description": {
                "type": "string"
              }

            }
          }
        },

        "canonicals": {
          "type": "array",

          "items": {
            "type": "object",

            "required": [
              "id",
              "domainId",
              "name",
              "description"
            ],

            "properties": {

              "id": {
                "type": "string"
              },

              "domainId": {
                "type": "string"
              },

              "name": {
                "type": "string"
              },

              "description": {
                "type": "string"
              }

            }
          }
        },

        "relationships": {
          "type": "array",

          "items": {
            "type": "object",

            "required": [
              "source",
              "target",
              "type"
            ],

            "properties": {

              "source": {
                "type": "string"
              },

              "target": {
                "type": "string"
              },

              "type": {
                "type": "string"
              }

            }
          }
        },

        "intents": {
          "type": "array",

          "items": {
            "type": "object",

            "required": [
              "id",
              "canonicalId",
              "name",
              "prompt"
            ],

            "properties": {

              "id": {
                "type": "string"
              },

              "canonicalId": {
                "type": "string"
              },

              "name": {
                "type": "string"
              },

              "prompt": {
                "type": "string"
              }

            }
          }
        }

      }
    }
  }
}